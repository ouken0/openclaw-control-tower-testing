// API Credits Types
export interface ApiCreditInfo {
  provider: string;
  displayName: string;
  icon: string;
  totalCredits: number;      // in currency units (USD)
  usedCredits: number;       // in currency units (USD)
  remainingCredits: number;  // in currency units (USD)
  percentUsed: number;       // 0-100
  resetDate: string;         // ISO date string
  daysUntilReset: number;
  rateLimitPerMinute: number;
  currentRateUsage: number;
  status: 'healthy' | 'warning' | 'critical' | 'exhausted';
  lastUpdated: string;
  // Per-agent breakdown
  agentUsage: {
    agentName: string;
    tokensUsed: number;
    tokenLimit: number;
    costUSD: number;
    requests: number;
    requestLimit: number;
  }[];
}

export interface ApiCreditsData {
  providers: ApiCreditInfo[];
  totalMonthlyBudget: number;
  totalUsed: number;
  totalRemaining: number;
  overallHealth: 'healthy' | 'warning' | 'critical';
  lastFullRefresh: string;
}

