// Calculate days until next reset
export function getDaysUntilReset(resetDay: number): number {
  const now = new Date();
  const currentDay = now.getDate();
  const currentMonth = now.getMonth();
  const currentYear = now.getFullYear();
  
  let nextReset: Date;
  if (currentDay >= resetDay) {
    // Next reset is next month
    nextReset = new Date(currentYear, currentMonth + 1, resetDay);
  } else {
    // Reset is this month
    nextReset = new Date(currentYear, currentMonth, resetDay);
  }
  
  const diffTime = nextReset.getTime() - now.getTime();
  return Math.ceil(diffTime / (1000 * 60 * 60 * 24));
}

// Get provider status based on usage percentage
export function getProviderStatus(percentUsed: number): ApiCreditInfo['status'] {
  if (percentUsed >= 100) return 'exhausted';
  if (percentUsed >= 90) return 'critical';
  if (percentUsed >= 75) return 'warning';
  return 'healthy';
}

// Get status color
export function getStatusColor(status: ApiCreditInfo['status']): string {
  switch (status) {
    case 'healthy': return '#22c55e';
    case 'warning': return '#eab308';
    case 'critical': return '#f97316';
    case 'exhausted': return '#ef4444';
  }
}

