import { useState, useEffect, useCallback } from 'react';

// Simple types (matching lib/types.ts)
interface Agent {
  id: string;
  name: string;
  role: string;
  model: string;
  provider: string;
  status: 'active' | 'idle' | 'error' | 'unknown';
  lastActivity: string;
  successRate: number;
  tokenUsage: {
    input: number;
    output: number;
  };
  avgResponseTime: number;
  tasksCompleted: number;
  currentTask?: string;
}

interface Metrics {
  totalAgents: number;
  activeAgents: number;
  idleAgents: number;
  errorAgents: number;
  overallSuccessRate: number;
  totalTokenUsage: {
    input: number;
    output: number;
  };
  avgResponseTime: number;
  uptime: string;
}

interface FedStatusData {
  timestamp: string;
  federation: string;
  version: string;
  agents: Agent[];
  metrics: Metrics;
}

// API call function to fetch real data
async function fetchFedStatusData(): Promise<FedStatusData> {
  try {
    const response = await fetch('/api/fedstatus');
    if (!response.ok) {
      throw new Error('Failed to fetch data');
    }
    return await response.json();
  } catch (error) {
    console.error('API fetch error:', error);
    // Fallback to mock data if API fails
    return getMockData();
  }
}

