import { useState, useEffect } from 'react';
import ApiCreditsPanel from '../components/ApiCreditsPanel';
import SpeedometerGauge from '../components/SpeedometerGauge';

interface Agent {
  id: string;
  name: string;
  role: string;
  model: string;
  provider: string;
  status: 'active' | 'idle' | 'error' | 'unknown';
  lastActivity: string;
  successRate: number;
  tokenUsage: {
    input: number;
    output: number;
  };
  avgResponseTime: number;
  tasksCompleted: number;
  currentTask?: string;
}

interface FedStatusData {
  timestamp: string;
  federation: string;
  version: string;
  agents: Agent[];
  metrics: {
    totalAgents: number;
    activeAgents: number;
    idleAgents: number;
    errorAgents: number;
    overallSuccessRate: number;
    totalTokenUsage: {
      input: number;
      output: number;
    };
    avgResponseTime: number;
    uptime: string;
  };
}

